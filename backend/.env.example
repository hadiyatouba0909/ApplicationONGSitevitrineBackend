PORT=5000
NODE_ENV=production

# ─── BASE DE DONNÉES ─────────────────────────────────────────────────
# Sur Render : copier le "External Database URL" fourni par le service PostgreSQL Render
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# En local uniquement (ignoré si DATABASE_URL est défini)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site_vitrine
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=remplacer_par_une_chaine_tres_longue_et_aleatoire_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── ADMIN ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@votre-ong.org
ADMIN_PASSWORD=VotreMotDePasseAdmin@2024!

# ─── CORS (Frontend Vercel) ──────────────────────────────────────────
FRONTEND_URL=https://votre-app.vercel.app
